        "        verdict = 'non-stationary'\n",
        "    elif adf_rejects and kpss_rejects:\n",
        "        verdict = 'contradictory'\n",
        "    else:\n",
        "        verdict = 'inconclusive'\n",
        "\n",
        "    return {\n",
